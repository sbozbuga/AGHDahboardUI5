<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.ui.layout.form">
	<Dialog
		id="advancedFilterDialog"
		title="Advanced Filter"
		contentWidth="600px"
		resizable="true"
		draggable="true">
		<content>
			<Table
				id="filterTable"
				ariaLabelledBy="advancedFilterTitle"
				items="{view>/advancedFilters}"
				mode="None"
				growing="false"
				width="100%">
				<headerToolbar>
					<OverflowToolbar>
						<Title id="advancedFilterTitle" text="Conditions ({= ${view>/advancedFilters} ? ${view>/advancedFilters}.length : 0 })" level="H4"/>
						<ToolbarSpacer/>
						<Button icon="sap-icon://add" text="{i18n>addCondition}" press=".onAddFilterRow" type="Ghost"/>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column width="30%">
						<Text text="{i18n>column}" />
					</Column>
					<Column width="30%">
						<Text text="{i18n>operator}" />
					</Column>
					<Column width="30%">
						<Text text="{i18n>value}" />
					</Column>
					<Column width="10%" hAlign="End">
						<Text text="" />
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<ComboBox tooltip="{i18n>column}" selectedKey="{view>column}" width="100%">
								<core:Item key="time" text="Time" />
								<core:Item key="client" text="Client" />
								<core:Item key="question/name" text="Question" />
								<core:Item key="question/type" text="Type" />
								<core:Item key="status" text="Status" />
								<core:Item key="blocked" text="Blocked" />
								<core:Item key="elapsedMs" text="Elapsed (ms)" />
								<core:Item key="upstream" text="Upstream" />
								<core:Item key="reason" text="Reason" />
								<core:Item key="filterId" text="Filter ID" />
								<core:Item key="rule" text="Rule" />
							</ComboBox>
							<ComboBox tooltip="{i18n>operator}" selectedKey="{view>operator}" width="100%">
								<core:Item key="EQ" text="Equals" />
								<core:Item key="Contains" text="Contains" />
								<core:Item key="GT" text="Greater Than" />
								<core:Item key="LT" text="Less Than" />
								<core:Item key="GE" text="Greater or Equal" />
								<core:Item key="LE" text="Less or Equal" />
								<core:Item key="NE" text="Not Equal" />
								<core:Item key="StartsWith" text="Starts With" />
								<core:Item key="EndsWith" text="Ends With" />
							</ComboBox>
							<Input tooltip="{i18n>value}" value="{view>value}" width="100%" placeholder="{i18n>value}" submit=".onConfirmAdvancedFilter" maxLength="200" />
							<Button icon="sap-icon://delete" type="Transparent" press=".onRemoveFilterRow" tooltip="{i18n>removeCondition}" />
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<buttons>
			<Button text="{i18n>clearAllAction}" press=".onClearAdvancedFilters" type="Transparent" />
			<Button text="{i18n>applyAction}" press=".onConfirmAdvancedFilter" type="Emphasized" />
			<Button text="{i18n>cancelAction}" press=".onCancelAdvancedFilter" />
		</buttons>
	</Dialog>
</core:FragmentDefinition>
