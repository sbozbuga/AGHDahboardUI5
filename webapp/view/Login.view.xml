<mvc:View
	controllerName="ui5.aghd.controller.Login"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	displayBlock="true"
	busyIndicatorDelay="0"
>
	<App>
		<Page title="AdGuard Home Login">
			<VBox class="sapUiSmallMargin" justifyContent="Center" alignItems="Center" height="100%">
				<Panel width="300px" headerText="Sign In">
					<content>
						<VBox>
							<label text="Username" labelFor="usernameInput" required="true" />
							<input
								id="usernameInput"
								value="{/username}"
								required="true"
								placeholder="Enter your username"
								submit=".onLoginPress"
								liveChange=".onInputChange"
								maxlength="50"
								showClearIcon="true"
							/>

							<label text="Password" labelFor="passwordInput" class="sapUiSmallMarginTop" required="true" />
							<input
								id="passwordInput"
								value="{/password}"
								required="true"
								type="Password"
								placeholder="Enter your password"
								submit=".onLoginPress"
								liveChange=".onInputChange"
								maxlength="100"
								showValueHelp="true"
								valueHelpIconSrc="sap-icon://show"
								valueHelpRequest=".onShowPassword"
								showClearIcon="true"
							/>

							<button
								text="{i18n>logIn}"
								type="Emphasized"
								press=".onLoginPress"
								class="sapUiMediumMarginTop"
								width="100%"
							/>
						</VBox>
					</content>
				</Panel>
			</VBox>
		</Page>
	</App>
</mvc:View>
